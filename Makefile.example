SHELL := /bin/bash

.PHONY: help ios android android-parallel ios-parallel

help: ## Mostrar este mensaje de ayuda
	@echo "Uso: make [comando]"
	@echo ""
	@echo "Comandos disponibles:"
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

ios: ## Ejecutar tests en un dispositivo iOS específico
	@PLATFORM_NAME=ios \
	DEVICE_NAME="NOMBRE DEL DISPOSITIVO" \
	PLATFORM_VERSION=VERSION DEL SISTEMA OPERATIVO \
	UDID=ID DEL DISPOSITIVO (OBTENER DESDE IOS CONFIGURATION) \
	USE_PREBUILT_WDA=True \
	pytest -v

android: ## Ejecutar tests en un dispositivo Android específico
	@DEVICE_NAME="NOMBRE DEL DISPOSITIVO" \
	PLATFORM_VERSION=VERSION DEL SISTEMA OPERATIVO \
	pytest -v

android-parallel: ## Ejecutar tests en paralelo sobre 2 dispositivos Android definidos en devices.json
	@PLATFORM_NAME=android \
	pytest -n 2 -v

ios-parallel: ## Ejecutar tests en paralelo sobre 2 dispositivos iOS definidos en devices.json
	@PLATFORM_NAME=ios \
	USE_PREBUILT_WDA=True \
	pytest -n 2 -v